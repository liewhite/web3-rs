# Claude: 复制到 <project>/rust/Cargo.toml。
# - `<PROJECT_NAME>` 填项目名（蛇形下划线）
# - `<WEB3RS_SHA>` 填 skill/scripts/fetch_web3rs_sha.sh 的输出（7+ 字符）
# - Phase 4 的 production/Cargo.toml 也用同一个 sha

[package]
name = "<PROJECT_NAME>"
version = "0.1.0"
edition = "2024"

[dependencies]
alloy = { version = "1.1", features = ["full"] }
eyre = "0.6"
revm = { version = "34", default-features = false, features = ["std", "optional_eip3607", "optional_balance_check"] }
serde_json = "1"
tokio = { version = "1", features = ["macros", "rt-multi-thread"] }
tracing = "0.1"
clap = { version = "4", features = ["derive"] }

web3-rs = { git = "https://github.com/liewhite/web3-rs", rev = "<WEB3RS_SHA>", package = "flashseal-rs" }

[dev-dependencies]
# Phase 1-3 测试 + Phase 4 deploy_fork_verify 都放 tests/
